{
  "api_port": 8787,
  "admin_chat_ids": [1948669478],
  "alert_cooldown_sec": 300,
  "feed_digest_hours": 6,
  "freebies": {
    "enabled": true,
    "digest_hour": 13,
    "timezone": "Europe/Kyiv",
    "env_file": "/opt/review-roadmap/.env",
    "platforms": [
      "steam",
      "epic-games-store",
      "gog",
      "itch.io",
      "ubisoft",
      "origin",
      "battlenet",
      "android",
      "ios",
      "ps4",
      "xbox-one",
      "switch",
      "drm-free"
    ],
    "types": ["game", "loot", "beta", "early-access", "dlc"],
    "max_items": 50,
    "include_steam_search": true
  },
  "watch_interval_sec": 300,
  "alert_thresholds": {
    "disk_pct": 85,
    "load_1m": 4.0,
    "ram_pct": 90
  },
  "projects": [
    {
      "id": "polysniper",
      "name": "PolySniper Backtest",
      "source": "file",
      "path": "/opt/polysniper/data/run_status.json"
    },
    {
      "id": "review-roadmap",
      "name": "Review Roadmap",
      "source": "api"
    },
    {
      "id": "reddit-scraper",
      "name": "Reddit Scraper",
      "source": "api"
    }
  ],
  "probes": [
    {
      "id": "review-roadmap",
      "url": "http://127.0.0.1:8000/health/ready",
      "interval_sec": 60
    }
  ],
  "feeds": [
    {
      "name": "GamerPower",
      "url": "https://www.gamerpower.com/rss/giveaways",
      "limit": 5
    },
    {
      "name": "Hacker News",
      "url": "https://hnrss.org/frontpage",
      "limit": 5
    }
  ],
  "watch_urls": [
    {
      "name": "Epic Free",
      "url": "https://store.epicgames.com/en-US/free-games"
    },
    {
      "name": "Steam Free",
      "url": "https://store.steampowered.com/search/?specials=1&maxprice=free"
    }
  ],
  "ssl_domains": [
    "github.com"
  ],
  "git_dirs": [
    "/opt/telegramvps",
    "/opt/review-roadmap",
    "/opt/polysniper"
  ],
  "shell": {
    "enabled": true,
    "cwd": "/opt",
    "timeout_sec": 20,
    "max_output": 3500,
    "allowed_prefixes": []
  },
  "services": [
    {"name": "reviewbot", "unit": "reviewbot.service"},
    {"name": "reviewapi", "unit": "reviewapi.service"},
    {"name": "telegramvps", "unit": "telegramvps.service"}
  ]
}